# ==============================================================================
# ENVIRONMENT MODULE CONFIGURATION - NEXUS Platform
# Copy this file to .env or configure these variables in local/CI environments.
# Do NOT commit the actual .env file or real secrets to the repository.
# ==============================================================================

# 1. CORE GEMINI AI API (Automatically handled by AI Studio UI Secrets tab)
GEMINI_API_KEY=your-gemini-api-key

# 2. APPLICATION RUNTIME & SYSTEM DEPLOYMENT
APP_URL=https://your-applet-url.run.app
NODE_ENV=development

# 3. DURABLE DATABASE LAYER (Optional - falls back to offline JSON if unspecified)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/nexus?retryWrites=true&w=majority
MONGODB_DB_NAME=nexus

# 4. SECURE GOOGLE OAUTH CONFIGURATION
# Set these variables to enable Google Sign-In and Google APIs flow
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# 5. RESEND TRANSACTIONAL EMAIL ENGINE
RESEND_API_KEY=re_your-resend-api-key-here

# 6. CLOUDINARY IMAGE & CDN HOSTING
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret
CLOUDINARY_UPLOAD_PRESET=your-cloudinary-upload-preset
